# ── Firebase Admin (for leads + Firestore writes) ─────────────────────────────
FIREBASE_SERVICE_ACCOUNT=./service-account.json

# ── SMTP Email ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key

# ── Resend (primary transactional email provider) ─────────────────────────────
RESEND_API_KEY=your-resend-api-key

# ── Lead notification recipient ───────────────────────────────────────────────
# Email address that receives new-lead notifications from the website form.
# Set this in your deployment environment (Vercel / Cloud Run / local .env).
LEAD_NOTIFICATION_EMAIL=leads@ministrymotion.com

# ── Twilio (SMS notifications) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
SALES_ADMIN_PHONES=+1xxxxxxxxxx

# ── HubSpot CRM ───────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=your-hubspot-pat
